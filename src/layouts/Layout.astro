---
import '../styles/global.css'
import { SITE } from '../lib/config'

interface Props { title?: string; description?: string }
const { title = `${SITE.name} — ${SITE.tagline}`, description = `Street tacos around town. Find our truck, see the menu, order for catering.` } = Astro.props
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://images.unsplash.com" />
</head>
<body class="bg-warm-white text-dark antialiased">
  <nav class="sticky top-0 z-50 bg-dark text-warm-white">
    <div class="mx-auto max-w-6xl flex items-center justify-between px-6 py-3">
      <a href="/" class="text-xl font-black tracking-tight">🌮 <span class="text-lime">CALICO</span> TACO</a>
      <div class="hidden md:flex items-center gap-5 text-sm font-medium">
        <a href="#menu" class="text-muted hover:text-lime transition-colors">Menu</a>
        <a href="#schedule" class="text-muted hover:text-lime transition-colors">Find Us</a>
        <a href="#order" class="text-muted hover:text-lime transition-colors">Order</a>
        <a href="#catering" class="text-muted hover:text-lime transition-colors">Catering</a>
        <a href="#order" class="rounded-lg bg-lime px-4 py-2 text-dark hover:bg-lime-dark transition-colors">Order Now</a>
      </div>
    </div>
  </nav>
  <main><slot /></main>

  <!-- Demo Disclaimer -->
  <div class="bg-yellow-50 border-y border-yellow-200 py-3 px-6 text-center">
    <p class="text-xs text-yellow-800">
      <strong>Portfolio Demo</strong> — This is a fictional business created by <a href="https://upstate-web.com" class="underline hover:text-yellow-900">Upstate Web Co</a>. All names, locations, and details are entirely fictional.
    </p>
  </div>

  <footer class="bg-dark text-muted">
    <div class="mx-auto max-w-6xl px-6 py-10">
      <div class="grid md:grid-cols-3 gap-8">
        <div>
          <p class="text-xl font-black text-warm-white">🌮 <span class="text-lime">CALICO</span> TACO</p>
          <p class="text-sm mt-2">{SITE.tagline}</p>
        </div>
        <div class="text-sm">
          <p class="font-medium text-warm-white mb-2">Contact</p>
          <p>{SITE.phone}</p>
          <p><a href={`mailto:${SITE.email}`} class="hover:text-lime">{SITE.email}</a></p>
          <p class="mt-1"><a href="#" class="hover:text-lime">Instagram {SITE.instagram}</a></p>
        </div>
        <div class="text-sm">
          <p class="font-medium text-warm-white mb-2">Order Delivery</p>
          <div class="flex gap-3">
            <a href="#" class="hover:text-lime">Uber Eats</a>
            <a href="#" class="hover:text-lime">DoorDash</a>
            <a href="#" class="hover:text-lime">Grubhub</a>
          </div>
        </div>
      </div>
      <div class="mt-8 pt-6 border-t border-muted/20 text-center text-xs">
        &copy; {new Date().getFullYear()} {SITE.name}. Built by <a href="https://upstate-web.com" class="text-lime hover:underline">Upstate Web Co</a>
      </div>
    </div>
  </footer>
</body>
</html>
