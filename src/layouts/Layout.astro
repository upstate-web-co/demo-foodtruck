---
import '../styles/global.css'
import { SITE } from '../lib/config'

interface Props { title?: string; description?: string }
const { title = `${SITE.name} — ${SITE.tagline}`, description = `Street tacos around town. Find our truck, see the menu, order for catering.` } = Astro.props
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="noindex, nofollow" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://images.unsplash.com/photo-1519741497674-611481863552?w=1200<meta name="robots" content="noindex, nofollow" />q=80" />
  <link rel="preconnect" href="https://images.unsplash.com" />
</head>
<body class="bg-warm-white text-dark antialiased">
  <nav class="sticky top-0 z-50 bg-dark text-warm-white">
    <div class="mx-auto max-w-6xl flex items-center justify-between px-6 py-3">
      <a href="/" class="text-xl font-black tracking-tight">🌮 <span class="text-lime">CALICO</span> TACO</a>
      <div class="hidden md:flex items-center gap-5 text-sm font-medium">
        <a href="#menu" class="text-muted hover:text-lime transition-colors">Menu</a>
        <a href="#schedule" class="text-muted hover:text-lime transition-colors">Find Us</a>
        <a href="#order" class="text-muted hover:text-lime transition-colors">Order</a>
        <a href="#catering" class="text-muted hover:text-lime transition-colors">Catering</a>
        <a href="#order" class="rounded-lg bg-lime px-4 py-2 text-dark hover:bg-lime-dark transition-colors">Order Now</a>
      </div>
      <div class="flex items-center gap-2">
        <button id="cart-toggle" class="relative p-2 text-warm-white" aria-label="Open cart">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
          <span id="cart-badge" class="hidden absolute -top-1 -right-1 w-5 h-5 rounded-full bg-hot-orange text-white text-xs flex items-center justify-center">0</span>
        </button>
        <button id="mobile-menu-btn" class="md:hidden text-warm-white" aria-label="Open menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Cart backdrop -->
  <div id="cart-backdrop" class="hidden fixed inset-0 z-[65] bg-black/40"></div>
  <!-- Cart drawer -->
  <div id="cart-drawer" class="fixed top-0 right-0 z-[70] h-full w-80 bg-warm-white shadow-xl transform translate-x-full transition-transform duration-300 flex flex-col">
    <div class="flex items-center justify-between p-4 border-b border-dark/10">
      <h3 class="font-bold text-dark">Your Order</h3>
      <button id="cart-close" class="text-muted hover:text-dark">✕</button>
    </div>
    <div id="cart-items" class="flex-1 overflow-y-auto p-4 text-dark"></div>
    <div class="border-t border-dark/10 p-4">
      <div class="flex justify-between font-bold text-dark mb-3">
        <span>Subtotal</span><span id="cart-subtotal">$0.00</span>
      </div>
      <button id="cart-checkout" class="w-full py-3 rounded-lg bg-lime text-dark font-bold hover:bg-lime-dark transition-colors">Pre-Order for Pickup</button>
      <p id="cart-checkout-msg" class="hidden mt-2 text-xs text-muted text-center">
        This is a portfolio demo by <a href="https://upstate-web.com" class="underline">Upstate Web Co</a>. In production, this connects to secure Stripe checkout.
      </p>
    </div>
  </div>

  <!-- Mobile menu overlay -->
  <div id="mobile-menu" class="hidden fixed inset-0 z-[60] flex-col items-center justify-center gap-6 bg-dark text-warm-white">
    <button id="mobile-menu-close" class="absolute top-4 right-6 text-warm-white" aria-label="Close menu">
      <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <a href="#menu" class="text-xl font-medium text-muted hover:text-lime transition-colors">Menu</a>
    <a href="#schedule" class="text-xl font-medium text-muted hover:text-lime transition-colors">Find Us</a>
    <a href="#order" class="text-xl font-medium text-muted hover:text-lime transition-colors">Order</a>
    <a href="#catering" class="text-xl font-medium text-muted hover:text-lime transition-colors">Catering</a>
    <a href="#order" class="mt-2 rounded-lg bg-lime px-6 py-3 text-lg font-bold text-dark hover:bg-lime-dark transition-colors">Order Now</a>
  </div>
  <main><slot /></main>

  <!-- Demo Disclaimer -->
  <div class="bg-yellow-50 border-y border-yellow-200 py-3 px-6 text-center">
    <p class="text-xs text-yellow-800">
      <strong>Portfolio Demo</strong> — This is a fictional business created by <a href="https://upstate-web.com" class="underline hover:text-yellow-900">Upstate Web Co</a>. All names, locations, and details are entirely fictional.
    </p>
  </div>

  <footer class="bg-dark text-muted">
    <div class="mx-auto max-w-6xl px-6 py-10">
      <div class="grid md:grid-cols-3 gap-8">
        <div>
          <p class="text-xl font-black text-warm-white">🌮 <span class="text-lime">CALICO</span> TACO</p>
          <p class="text-sm mt-2">{SITE.tagline}</p>
        </div>
        <div class="text-sm">
          <p class="font-medium text-warm-white mb-2">Contact</p>
          <p>{SITE.phone}</p>
          <p><a href={`mailto:${SITE.email}`} class="hover:text-lime">{SITE.email}</a></p>
          <p class="mt-1"><a href="#" class="hover:text-lime">Instagram {SITE.instagram}</a></p>
        </div>
        <div class="text-sm">
          <p class="font-medium text-warm-white mb-2">Order Delivery</p>
          <div class="flex gap-3">
            <a href="#" class="hover:text-lime">Uber Eats</a>
            <a href="#" class="hover:text-lime">DoorDash</a>
            <a href="#" class="hover:text-lime">Grubhub</a>
          </div>
        </div>
      </div>
      <div class="mt-8 pt-6 border-t border-muted/20 text-center text-xs">
        &copy; {new Date().getFullYear()} {SITE.name}. Built by <a href="https://upstate-web.com" class="text-lime hover:underline">Upstate Web Co</a>
      </div>
    </div>
  </footer>
  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const close = document.getElementById('mobile-menu-close');
    btn?.addEventListener('click', () => menu?.classList.replace('hidden', 'flex'));
    close?.addEventListener('click', () => menu?.classList.replace('flex', 'hidden'));
    menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => menu?.classList.replace('flex', 'hidden')));
  </script>
  <script>
    let cart: {name: string; price: number; qty: number}[] = [];

    function addToCart(name: string, price: string) {
      const existing = cart.find(i => i.name === name);
      if (existing) { existing.qty++; } else { cart.push({ name, price: parseFloat(price), qty: 1 }); }
      updateCartUI();
    }

    function removeFromCart(index: number) { cart.splice(index, 1); updateCartUI(); }
    function changeQty(index: number, delta: number) { cart[index].qty += delta; if (cart[index].qty < 1) removeFromCart(index); else updateCartUI(); }

    function updateCartUI() {
      const badge = document.getElementById('cart-badge')!;
      const items = document.getElementById('cart-items')!;
      const subtotal = document.getElementById('cart-subtotal')!;
      const count = cart.reduce((s, i) => s + i.qty, 0);
      badge.textContent = String(count);
      badge.classList.toggle('hidden', count === 0);
      items.innerHTML = cart.map((item, i) => `
        <div class="flex items-center justify-between py-3 border-b border-dark/10">
          <div class="flex-1">
            <p class="font-bold text-sm">${item.name}</p>
            <p class="text-xs text-muted">$${item.price.toFixed(2)}</p>
          </div>
          <div class="flex items-center gap-2">
            <button data-qty-minus="${i}" class="w-6 h-6 rounded bg-dark/10 text-sm font-bold">−</button>
            <span class="text-sm w-4 text-center">${item.qty}</span>
            <button data-qty-plus="${i}" class="w-6 h-6 rounded bg-dark/10 text-sm font-bold">+</button>
            <button data-remove="${i}" class="ml-2 text-hot-orange text-xs">✕</button>
          </div>
        </div>
      `).join('');
      subtotal.textContent = '$' + cart.reduce((s, i) => s + i.price * i.qty, 0).toFixed(2);
      // Re-bind cart item buttons
      items.querySelectorAll('[data-qty-minus]').forEach(b => b.addEventListener('click', () => changeQty(Number((b as HTMLElement).dataset.qtyMinus), -1)));
      items.querySelectorAll('[data-qty-plus]').forEach(b => b.addEventListener('click', () => changeQty(Number((b as HTMLElement).dataset.qtyPlus), 1)));
      items.querySelectorAll('[data-remove]').forEach(b => b.addEventListener('click', () => removeFromCart(Number((b as HTMLElement).dataset.remove))));
    }

    document.getElementById('cart-toggle')?.addEventListener('click', () => {
      document.getElementById('cart-drawer')?.classList.toggle('translate-x-full');
      document.getElementById('cart-backdrop')?.classList.toggle('hidden');
    });
    document.getElementById('cart-close')?.addEventListener('click', () => {
      document.getElementById('cart-drawer')?.classList.add('translate-x-full');
      document.getElementById('cart-backdrop')?.classList.add('hidden');
    });
    document.getElementById('cart-backdrop')?.addEventListener('click', () => {
      document.getElementById('cart-drawer')?.classList.add('translate-x-full');
      document.getElementById('cart-backdrop')?.classList.add('hidden');
    });
    document.getElementById('cart-checkout')?.addEventListener('click', () => {
      document.getElementById('cart-checkout-msg')?.classList.remove('hidden');
    });

    // Expose for inline onclick from index
    (window as any).addToCart = addToCart;
  </script>
</body>
</html>
