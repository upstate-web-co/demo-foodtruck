---
/**
 * Notification mockup — "phone reveal" for the Taco ad.
 * Script: Owner checks phone after morning prep + drive to location.
 * Tagline: UWC: for quiet mornings.
 */
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Notifications — Calico Taco</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-neutral-900 min-h-screen text-white">
  <div class="flex items-center justify-between px-6 py-2 text-xs text-white/60">
    <span>10:32 AM</span>
    <div class="flex items-center gap-1"><span>5G</span><span>📶</span><span>🔋 81%</span></div>
  </div>

  <div class="px-6 pt-4 pb-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-white/50">Good morning</p>
        <h1 class="text-2xl font-bold">🌮 Calico Taco</h1>
      </div>
      <div class="relative">
        <div class="w-10 h-10 rounded-full bg-lime-500/20 flex items-center justify-center text-lg">🌮</div>
        <div class="absolute -top-1 -right-1 w-5 h-5 rounded-full bg-red-500 flex items-center justify-center text-[10px] font-bold">9</div>
      </div>
    </div>
  </div>

  <div class="px-6 grid grid-cols-3 gap-3 mb-6">
    <div class="bg-white/5 border border-white/10 rounded-xl p-3 text-center">
      <p class="text-2xl font-bold text-lime-400">9</p>
      <p class="text-[10px] text-white/50 mt-1">Pre-Orders</p>
    </div>
    <div class="bg-white/5 border border-white/10 rounded-xl p-3 text-center">
      <p class="text-2xl font-bold text-green-400">$142</p>
      <p class="text-[10px] text-white/50 mt-1">Revenue</p>
    </div>
    <div class="bg-white/5 border border-white/10 rounded-xl p-3 text-center">
      <p class="text-2xl font-bold text-orange-400">6</p>
      <p class="text-[10px] text-white/50 mt-1">AI Chats</p>
    </div>
  </div>

  <div class="px-6">
    <h2 class="text-sm font-semibold text-white/40 uppercase tracking-wider mb-4">This morning</h2>
    <div class="space-y-3">
      <div class="bg-white/5 border border-white/10 rounded-xl p-4">
        <div class="flex items-start justify-between">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-lime-500/20 flex items-center justify-center text-sm">🛒</div>
            <div>
              <p class="text-sm font-medium">3 pre-orders for lunch pickup</p>
              <p class="text-xs text-white/40">Al Pastor × 2, Birria × 4, Elote Bowl × 1</p>
            </div>
          </div>
          <span class="text-[10px] text-white/30">5m ago</span>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-4">
        <div class="flex items-start justify-between">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-blue-500/20 flex items-center justify-center text-sm">💬</div>
            <div>
              <p class="text-sm font-medium">AI answered "Where are you today?"</p>
              <p class="text-xs text-white/40">Told them Central Park, 11am–2pm · they ordered</p>
            </div>
          </div>
          <span class="text-[10px] text-white/30">18m ago</span>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-4">
        <div class="flex items-start justify-between">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-blue-500/20 flex items-center justify-center text-sm">💬</div>
            <div>
              <p class="text-sm font-medium">AI handled "What's spicy on the menu?"</p>
              <p class="text-xs text-white/40">Recommended El Diablo · customer added to cart</p>
            </div>
          </div>
          <span class="text-[10px] text-white/30">35m ago</span>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-4">
        <div class="flex items-start justify-between">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-green-500/20 flex items-center justify-center text-sm">💳</div>
            <div>
              <p class="text-sm font-medium">$47 order confirmed via Stripe</p>
              <p class="text-xs text-white/40">6 tacos + nachos + 2 horchatas · pickup at 11:30</p>
            </div>
          </div>
          <span class="text-[10px] text-white/30">42m ago</span>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-4">
        <div class="flex items-start justify-between">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-orange-500/20 flex items-center justify-center text-sm">📋</div>
            <div>
              <p class="text-sm font-medium">Catering inquiry for Saturday</p>
              <p class="text-xs text-white/40">40 people · outdoor birthday · AI gathered all details</p>
            </div>
          </div>
          <span class="text-[10px] text-white/30">1h ago</span>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-4">
        <div class="flex items-start justify-between">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-lime-500/20 flex items-center justify-center text-sm">🛒</div>
            <div>
              <p class="text-sm font-medium">4 more pre-orders while you drove</p>
              <p class="text-xs text-white/40">All for today's location · ready when you open</p>
            </div>
          </div>
          <span class="text-[10px] text-white/30">1h ago</span>
        </div>
      </div>
    </div>
  </div>

  <div class="px-6 py-8 mt-4">
    <div class="bg-lime-500/10 border border-lime-500/20 rounded-xl p-5 text-center">
      <p class="text-lime-400 text-sm font-medium">Customers found you before you even parked.</p>
      <p class="text-white/50 text-xs mt-1">9 orders · 6 AI chats · 1 catering lead · $142 confirmed</p>
    </div>
  </div>

  <div class="fixed bottom-0 left-0 right-0 bg-gradient-to-t from-neutral-900 via-neutral-900/80 to-transparent py-6 px-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-white text-lg font-bold">UWC</p>
        <p class="text-lime-400 text-sm">For quiet mornings.</p>
      </div>
      <p class="text-white/30 text-xs">upstate-web.com</p>
    </div>
  </div>
</body>
</html>
